# .env - Local Development Configuration
# ======================================

# GCP Project Data
GCP_PROJECT_ID=vciso-local-dev
GCP_REGION=us-central1

# AI Configuration
# Options: `anthropic_direct`, `vertex_ai`, `aws_bedrock`
AI_PROVIDER=vertex_ai
AI_FALLBACK_PROVIDER=vertex_ai


# Database Connections (Docker Compose defaults)
# PostgreSQL via asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/vciso_dev

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# GCP Pub/Sub Emulator
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=vciso-local-dev

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Email Settings (Google Workspace SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_system_account@yourdomain.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your_system_account@yourdomain.com
